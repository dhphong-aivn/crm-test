# ==============================================================================
# CRM App — Supabase environment variables
# ==============================================================================
# 1. Copy this file to `.env.local` (which is gitignored).
# 2. Replace placeholder values below with your Supabase project credentials.
# 3. Restart the dev server after editing (Next.js reads env at startup).
#
# Where to find these on Supabase:
#   Project Settings -> API
#     - Project URL           => NEXT_PUBLIC_SUPABASE_URL
#     - anon public key       => NEXT_PUBLIC_SUPABASE_ANON_KEY
#     - service_role key      => SUPABASE_SERVICE_ROLE_KEY (NEVER expose to client)
# ==============================================================================

# Public URL of your Supabase project (safe to expose to browser)
NEXT_PUBLIC_SUPABASE_URL=https://your-project-ref.supabase.co

# Public anon key (safe to expose — RLS enforces security)
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key-here

# Service role key — FULL DATABASE ACCESS, bypasses RLS.
# Only used server-side (in server actions / API routes). NEVER prefix with NEXT_PUBLIC_.
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key-here

# Optional: override site URL for auth redirects (default: http://localhost:3000)
NEXT_PUBLIC_SITE_URL=http://localhost:3000
